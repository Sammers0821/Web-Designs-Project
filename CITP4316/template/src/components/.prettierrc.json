{
    "$schema": "https://json.schemastore.org/prettierc",
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowsParens": "always",
    "vueIndentScriptsAndStyle": false,
    "singleAttributePerLine": true,
    "plugins": ["prettier-plugin-tailwindcss"],
    "tailwindStyleSheet": "./src/assets/style.css"
}